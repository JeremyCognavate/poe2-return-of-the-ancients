---
import { Image } from 'astro:assets';
import type { UniqueItem } from '../content/uniques';
import ConfidenceBadge from './ConfidenceBadge.astro';

interface Props { item: UniqueItem; }
const { item } = Astro.props;

type ImageModule = { default: ImageMetadata };
const allIcons = import.meta.glob<ImageModule>('../assets/uniques/*.png');
const icon = item.iconFile
  ? (await allIcons[`../assets/uniques/${item.iconFile}`]?.())?.default
  : null;

const implicits = item.implicits.join('||');
const explicits = item.explicits.join('||');
---

<div
  class="unique-wrap"
  tabindex="0"
  data-tooltip-type="unique"
  data-tooltip-name={item.name}
  data-tooltip-base={item.baseType}
  data-tooltip-implicits={implicits}
  data-tooltip-explicits={explicits}
  data-tooltip-icon-url={item.iconUrl || ''}
  data-tooltip-req-level={item.reqLevel?.toString() || ''}
  data-tooltip-confidence={item.confidence}
  data-tooltip-note={item.note || ''}
>
  <div class="unique-card">
    <div class="unique-card-icon">
      {icon
        ? <Image src={icon} alt={item.name} width={64} height={64} format="webp" quality={92} loading="lazy" />
        : <div class="unique-card-icon-fallback">⬥</div>
      }
    </div>
    <div class="unique-card-meta">
      <div class="unique-card-name">{item.name}</div>
      <div class="unique-card-base">{item.baseType}{item.itemClass && item.itemClass !== item.baseType ? ` · ${item.itemClass}` : ''}</div>
      <div class="unique-card-tags">
        <ConfidenceBadge tier={item.confidence} />
        {item.spiritWalkerSynergy && <span class="badge badge-spirit">Spirit Walker</span>}
      </div>
    </div>
  </div>
</div>
