---
import { Image } from 'astro:assets';

interface Props {
  id: string;
  title: string;
  subtitle?: string;
  imageFile?: string;
  imageAlt?: string;
}

const { id, title, subtitle, imageFile, imageAlt } = Astro.props;

type ImageModule = { default: ImageMetadata };
const allImages = import.meta.glob<ImageModule>('../assets/images/*.{png,jpg,jpeg,webp,avif}');
const loader = imageFile ? allImages[`../assets/images/${imageFile}`] : null;
const image = loader ? (await loader()).default : null;
---

<section id={id} class="section">
  {image && (
    <a href={image.src} target="_blank" rel="noopener" class="section-hero-link" aria-label={`Open ${imageAlt ?? title} full size`}>
      <Image
        src={image}
        alt={imageAlt ?? title}
        widths={[640, 960, 1400, 1920]}
        sizes="(max-width: 768px) 100vw, calc(100vw - 280px)"
        loading="lazy"
        decoding="async"
        format="webp"
        quality={84}
        class="section-hero-img"
      />
    </a>
  )}
  <h2>{title}</h2>
  {subtitle && <p class="section-subtitle">{subtitle}</p>}
  <hr class="divider" />
  <slot />
</section>
